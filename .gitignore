__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
*.egg-info/
build/
dist/

# Local config / certs — never commit secrets
/config/
/certs/

# IDE
.vscode/
.idea/
*.swp

# Proprietary native libs (e.g. DatecsPay pinpad C library) — must
# stay on the deployment host but never be published. Build separately
# from the upstream source repo (see INSTALL_PINPAD.md).
*.so
*.a
*.o
*.dylib
*.dll

# Block ALL contents of the pinpad lib directory except the placeholder.
# Headers, sources, pre-built binaries — none of it ships in the repo.
odoo_erpnet_fp/drivers/pinpad/datecs_pay/lib/*
!odoo_erpnet_fp/drivers/pinpad/datecs_pay/lib/.gitkeep
.env
letsencrypt/

# Runtime data — local state, never commit
data/
